{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "jsx": "react-jsx",
    "paths": {
      "@/*": ["./*"],
      "@kwilt/arc-survey": ["./packages/arc-survey/src/index.ts"],
      "@kwilt/arc-survey/*": ["./packages/arc-survey/src/*"],
      "@kwilt/tokens": ["./packages/kwilt-tokens/src/index.ts"],
      "@kwilt/tokens/tailwind-preset": ["./packages/kwilt-tokens/src/tailwind-preset.ts"],
      "@kwilt/tokens/*": ["./packages/kwilt-tokens/src/*"],
      "@kwilt/sdk": ["./packages/kwilt-sdk/src/index.ts"],
      "@kwilt/sdk/*": ["./packages/kwilt-sdk/src/*"]
    },
    "types": [
      "node",
      "jest"
    ]
  },
  "exclude": [
    "node_modules",
    "supabase",
    "jest.setup.ts",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.spec.ts",
    "**/*.spec.tsx"
  ]
}
